# ------------------------------------------------------------
# Application
# ------------------------------------------------------------
APP_NAME="Amigo Secreto"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_FORCE_HTTPS=false

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database
# APP_PREVIOUS_KEYS=

# ------------------------------------------------------------
# Runtime / Security
# ------------------------------------------------------------
# PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

# ------------------------------------------------------------
# Logging
# ------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ------------------------------------------------------------
# Database
# ------------------------------------------------------------
# For local quick start, SQLite is easier:
DB_CONNECTION=sqlite
# DB_DATABASE=database/database.sqlite

# Example PostgreSQL config:
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=amigo_secreto
# DB_USERNAME=postgres
# DB_PASSWORD=secret

# ------------------------------------------------------------
# Session / Cache / Queue
# ------------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

CACHE_STORE=database
# CACHE_PREFIX=

QUEUE_CONNECTION=database
QUEUE_FAILED_DRIVER=database-uuids

# ------------------------------------------------------------
# Filesystem / Broadcast
# ------------------------------------------------------------
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ------------------------------------------------------------
# Redis (optional)
# ------------------------------------------------------------
MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ------------------------------------------------------------
# Mail
# ------------------------------------------------------------
# Use 'log' in local dev to avoid real sends.
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
# MAIL_URL=
# MAIL_EHLO_DOMAIN=

# ------------------------------------------------------------
# AWS / S3 (optional)
# ------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
# AWS_ENDPOINT=
# AWS_URL=

# ------------------------------------------------------------
# Frontend
# ------------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"

# ------------------------------------------------------------
# Operations Alerts
# ------------------------------------------------------------
# If TELEGRAM_BOT_TOKEN and TELEGRAM_CHAT_ID are set, alerts go ONLY to Telegram.
# If Telegram is not configured, alerts fallback to OPS_ALERT_EMAIL.
OPS_ALERT_EMAIL=ops@example.com
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=


OPS_STATUS_ALLOWED_EMAILS=admin@example.com

